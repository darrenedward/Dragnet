# Dragnet environment variables.
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and is the canonical place for secrets.

# ─────────────────────────────────────────────────────────────────────────────
# Database (Prisma + Postgres)
# ─────────────────────────────────────────────────────────────────────────────
# Used by src/lib/prisma.ts for all data. For Supabase, use the pooled
# connection (port 6543) with pgbouncer=true. The password should be the
# DATABASE password from Supabase, not your Supabase account password.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require"

# ─────────────────────────────────────────────────────────────────────────────
# Supabase project (Auth, Storage, Realtime — not the raw DB connection)
# ─────────────────────────────────────────────────────────────────────────────
# Project URL: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"

# Publishable (anon) key — safe to expose to the browser. Find it in the
# Supabase dashboard under Project Settings → API → Project API keys.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_YOUR_KEY"

# ─────────────────────────────────────────────────────────────────────────────
# AI / LLM (OpenAI-compatible endpoints)
# ─────────────────────────────────────────────────────────────────────────────
# Dragnet uses the OpenAI SDK to talk to any OpenAI-compatible endpoint.
# Default is OpenRouter (https://openrouter.ai/api/v1) — one key, hundreds of
# models from many providers (Anthropic, OpenAI, Qwen, Meta, etc.).
#
# For local models, point LLM_ENDPOINT at Ollama (http://localhost:11434/v1)
# or LM Studio (http://localhost:1234/v1).
#
# Pick chat + embedding models at runtime via the "LLM Settings" tab — the
# chosen values are written back to .env.local here on save.
LLM_ENDPOINT="https://openrouter.ai/api/v1"
LLM_API_KEY=""
LLM_MODEL=""
LLM_EMBEDDING_MODEL=""

# ─────────────────────────────────────────────────────────────────────────────
# App & Auth
# ─────────────────────────────────────────────────────────────────────────────
# Public URL of the deployed app — used for self-referential links and OAuth.
APP_URL="http://localhost:3300"

# Better Auth requires the base URL for session cookies and callbacks.
# Must match the actual URL the app is served from.
BETTER_AUTH_URL="http://localhost:3300"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3300"

# ─────────────────────────────────────────────────────────────────────────────
# Dragnet CLI & Pre-push Hook
# ─────────────────────────────────────────────────────────────────────────────
# API key for the pre-push hook and dragnet CLI. Generate one from the UI:
# Settings → API Keys → "New Key".
DRAGNET_API_KEY="dr_..."

# Base URL of the Dragnet instance (default: http://localhost:3300).
# Set this to the public URL if running remotely.
DRAGNET_URL="http://localhost:3300"

# ─────────────────────────────────────────────────────────────────────────────
# GitHub App (OAuth + HTTPS Clone)
# ─────────────────────────────────────────────────────────────────────────────
# Required for GitHub App OAuth flow. Create a GitHub App at:
# https://github.com/settings/apps
# Then fill in the values below.
# GITHUB_APP_ID — numeric App ID from the GitHub App settings page.
# GITHUB_APP_CLIENT_ID — from the "Client ID" section.
# GITHUB_APP_CLIENT_SECRET — generate one in the "Client secrets" section.
# GITHUB_APP_PRIVATE_KEY — base64-encoded PEM of the App's private key.
#   Generate a private key in the GitHub App settings → "Private keys" → "Generate a private key".
#   Then: base64 -w0 <path-to-pem>
GITHUB_APP_ID=""
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_CLIENT_SECRET=""
GITHUB_APP_PRIVATE_KEY=""
