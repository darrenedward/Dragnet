# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
DATABASE_URL=
# Example Supabase pooled connection (Note standard Prisma connection args and pgbouncer=true for port 6543):
# DATABASE_URL="postgresql://postgres.eearpeehveyowjfxwzoj:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Prisma connection string.
# Examples:
# - SQLite: "file:../data.db"
# - PostgreSQL: "postgresql://johndoe:mypassword@localhost:5432/mydb?schema=public"
# - MySQL/MariaDB: "mysql://johndoe:mypassword@localhost:3306/mydb"
#DATABASE_URL="file:../data.db"
DATABASE_URL="postgresql://postgres.eearpeehveyowjfxwzoj:REDACTED_SUPABASE_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
