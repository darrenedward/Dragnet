    "better-auth": "^1.6.19",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^16.2.9",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
