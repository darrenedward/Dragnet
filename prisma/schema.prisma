// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// v1 is single-tenant: one operator, all repos world-readable to that
// operator. The Organization/Member/Invitation models below are scaffolding
// for the multi-tenant v2 (tracked in CLAUDE.md under "Auth: Better Auth
// (planned — multi-tenant via organization plugin)"). Per the user's
// no-half-implementations rule, Repository/PullRequest/ReviewRun are NOT
// given organizationId foreign keys until the full multi-tenancy flow
// ships in one PR (backfill migration, auth binding to scope queries by
// org, UI for org switcher, etc.). Adding just the column now would
// suggest a tenant boundary that the rest of the stack does not enforce.
model Repository {
  id              String          @id
  name            String
  path            String?         @unique

  provider        String? // "local" | "github" | "gitlab"
  cloneUrl        String? // git@github.com:... or https://...
  cloneUrlHttps   String? // HTTPS URL for API calls (when cloneUrl is SSH)
  deployKeyCipher String?
  deployKeyIv     String?
  deployKeyTag    String?
  patCipher       String?
  patIv           String?
  patTag          String?
  webhookSecret   String? // HMAC secret (plaintext — needed to verify inbound webhooks)
  webhookId       String?
  lastFetchAt     DateTime?
  localPath       String? // server-managed clone directory

  baseBranch         String
  activeBranch       String
  triggerMode        String
  quietPeriodSeconds Int
  branchPattern      String
  status             String
  lastCommitHash     String
  lastCommitMessage  String
  lastActivityTime   String
  stabilizationTimer Int
  reviewsCount       Int
  indexedAt          String?
  securitySensitivePaths String[] @default([])
  runnerImage        String   @default("node:20-alpine")
  installCommand     String   @default("npm install")
  testCommand        String   @default("npm test && npm run lint")
  isPollingEnabled   Boolean  @default(false)
  reviewHistory      ReviewHistory[]
  pullRequests       PullRequest[]
  symbols            Symbol[]
  edges              Edge[]
  files              File[]

  @@map("repositories")
}

model ReviewLog {
  id            String   @id
  prId          String
  reviewRunId   String?  // nullable for backward compat — legacy rows have null
  reviewChunkId String?
  message       String
  level         String   // "info" | "warn" | "error" | "tool_call"
  createdAt     DateTime @default(now())

  @@index([prId, createdAt])
  @@index([reviewRunId, createdAt])
  @@index([reviewChunkId, createdAt])
  @@map("review_logs")
}

model ReviewHistory {
  id            String     @id
  repoId        String
  repoName      String
  branch        String
  commitHash    String
  triggerReason String
  status        String
  timestamp     String
  repository    Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@map("review_history")
}

model ReviewRun {
  id               String         @id
  prId             String
  repoId           String
  commitHash       String
  diffHash         String
  reviewConfigHash String
  status           String         // "in_progress" | "completed" | "failed"
  startedAt        DateTime
  completedAt      DateTime?
  model            String?
  rating           Int?
  reliability      String?        // "complete" | "partial" | "incomplete_security_review"
  refused          Boolean        @default(false)  // reviewer flagged it declined/skipped part of the PR
  refusalNote      String?        // topics the reviewer skipped, for the UI banner
  chunksTotal      Int            @default(0)
  chunksCompleted  Int            @default(0)
  chunksFailed     Int            @default(0)
  chunksSkipped    Int            @default(0)
  triggerReason    String?        // "manual" | "prepush" | "prcheck" | "webhook" | "legacy"
  forced           Boolean        @default(false)
  tokensUsed       Json?          // Phase 2 cost telemetry: { totalCostUsd, totalPromptTokens, totalCompletionTokens, providers[] }
  lastCheckpointAt DateTime?      // Phase 5 resume: last successful checkpoint write for an in-progress run
  pullRequest      PullRequest    @relation(fields: [prId], references: [id], onDelete: Cascade)
  reviewFindings   ReviewFinding[]
  reviewChunks     ReviewChunk[]

  @@index([prId, status, completedAt])
  @@index([repoId, status, completedAt])
  @@map("review_runs")
}

model ReviewChunk {
  id                       String    @id
  reviewRunId              String
  label                    String
  filePaths                String[]
  status                   String    // "pending" | "running" | "completed" | "failed" | "skipped" | "interrupted"
  skipReason               String?
  rating                   Int?
  summary                  String?
  errorMessage             String?
  lineCount                Int       @default(0)
  touchesSecuritySensitive Boolean   @default(false)
  startedAt                DateTime?
  completedAt              DateTime?
  lastCheckpointAt         DateTime?    // Phase 5 resume: last checkpoint write for this chunk
  reviewRun                ReviewRun @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)

  @@index([reviewRunId, status])
  @@map("review_chunks")
}

model PullRequest {
  id             String           @id
  repoId         String
  title          String
  sourceBranch   String
  targetBranch   String
  status         String
  author         String
  commitHash     String
  createdAt      String
  description    String?
  rating         Int?
  repository     Repository       @relation(fields: [repoId], references: [id], onDelete: Cascade)
  prFiles        PrFile[]
  reviewFindings ReviewFinding[]
  reviewRuns     ReviewRun[]

  @@map("pull_requests")
}

model PrFile {
  id              String      @id
  prId            String
  filename        String
  status          String
  additions       Int
  deletions       Int
  originalContent String?
  modifiedContent String?
  diff            String?
  pullRequest     PullRequest @relation(fields: [prId], references: [id], onDelete: Cascade)

  @@unique([prId, filename])
  @@map("pr_files")
}

model ReviewFinding {
  id                 String      @id
  prId               String
  reviewRunId        String?
  reviewChunkId      String?
  repoId             String
  category           String
  severity           String
  exploitability     String?     // "trivial" | "moderate" | "difficult" — how easy to exploit
  impact             String?     // "critical" | "high" | "medium" | "low" — blast radius if exploited
  filename           String
  line               Int?
  explanation        String
  diffSuggestion     String?
  evidenceChain      String?
  confidence         Float?
  verificationStatus String?
  verificationNote   String?
  source             String?
  timestamp          String
  fingerprint        String?     // symbol-anchored hash; stable across line shifts
  firstSeenRunId     String?     // run that first detected this issue (plain ID, no FK to avoid cascade surprises)
  lastSeenRunId      String?     // most recent run that still detected it
  resolvedAtRunId    String?     // run where it stopped appearing AND code at anchor had changed
  status             String?     // "open" | "resolved" | "wontfix"
  sourceHashAtInsert String?     // snapshot of Symbol.sourceHash when this finding was last detected
  pullRequest        PullRequest @relation(fields: [prId], references: [id], onDelete: Cascade)
  reviewRun          ReviewRun?  @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)

  @@index([reviewRunId])
  @@index([reviewChunkId])
  @@index([prId])
  @@index([repoId])
  @@index([prId, reviewRunId])
  @@index([prId, status])
  @@map("review_findings")
}

model Symbol {
  id         String  @id
  repoId     String
  filePath   String
  name       String
  kind       String
  language   String
  lineStart  Int
  lineEnd    Int
  signature  String?
  sourceHash String
  summary    String?
  summaryAt  BigInt?
  embedding  Unsupported("vector(1024)")?
  repository Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([repoId, filePath])
  @@index([repoId, name])
  @@index([repoId, filePath, lineStart, lineEnd])
  @@map("symbols")
}

model Edge {
  id       String  @id
  repoId   String
  fromId   String
  toId     String?
  toRaw    String?
  kind     String
  filePath String
  line     Int
  repository Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([repoId, toId, kind])
  @@index([repoId, toId])
  @@index([repoId, fromId, kind])
  @@index([repoId, fromId])
  @@index([repoId, filePath])
  @@map("edges")
}

model File {
  repoId   String
  filePath String
  fileHash String
  parsedAt BigInt
  repository Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@id([repoId, filePath])
  @@map("files")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  banned        Boolean   @default(false)
  role          String    @default("user")
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  organizations Organization[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  expiresAt    DateTime
  token        String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                      String    @id @default(cuid())
  userId                  String
  accountId               String
  providerId              String
  accessToken             String?
  refreshToken            String?
  idToken                 String?
  accessTokenExpiresAt    DateTime?
  refreshTokenExpiresAt   DateTime?
  scope                   String?
  password                String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  createdAt   DateTime @default(now())
  modifiedAt  DateTime @updatedAt
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  members     Member[]
  invitations Invitation[]

  @@map("organizations")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("member")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("members")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           String
  status         String       @default("pending")
  expiresAt      DateTime
  inviterId      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  prefix    String
  hash      String   @unique
  createdAt DateTime @default(now())
  lastUsedAt DateTime?
  revoked   Boolean  @default(false)

  @@map("api_keys")
}
